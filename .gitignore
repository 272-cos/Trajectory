# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
screenshots/

# Upstream publication snapshots saved on drift for human review.
# docs/UPSTREAM-PINS.json is the durable record; the PDFs themselves are
# throwaway review artifacts (DAFMAN ~40MB). CI uploads them as artifacts.
docs/upstream-snapshots/*.pdf
docs/upstream-snapshots/*.html

# Root-level junk patterns (prevent re-accumulation of session artifacts and
# ad-hoc downloads). Leading slash anchors to repo root only; subdir assets
# like public/icons/*.webp and src/**/*.jpg remain unaffected.
/*.zip
/*.rar
/*.7z
/*.tar
/*.tar.gz
/*.JPG
/*.PNG
/*.pdf
/claude.resume
/Trajectory*.html
/comparison*.jpg
/screenshot*.png
